#!/usr/bin/env python3

import subprocess
import sys
import argparse
import random

# ANSI Colors
GREEN = "\033[92m"
RED = "\033[91m"
YELLOW = "\033[93m"
CYAN = "\033[96m"
PURPLE = "\033[95m"
RESET = "\033[0m"

# Banner colors (bright only)
BANNER_COLORS = [
    "\033[92m",
    "\033[93m",
    "\033[96m",
    "\033[94m",
    "\033[95m"
]


def banner():

    color = random.choice(BANNER_COLORS)

    print(color + r"""
  ____ _   _       _____ _           _
 / ___| \ | |     |  ___(_)_ __   __| | ___ _ __
| |   |  \| |_____| |_  | | '_ \ / _` |/ _ \ '__|
| |___| |\  |_____|  _| | | | | | (_| |  __/ |
 \____|_| \_|     |_|   |_|_| |_|\__,_|\___|_|
""" + RESET)

    print(f"{CYAN}👨‍💻 Author:{RESET} Tony😎 (Rachapudi Rohith)")
    print(f"{CYAN}🔗 LinkedIn:{RESET} https://www.linkedin.com/in/rohithrachapudi96")
    print(f"{CYAN}{'-'*52}{RESET}")


def check_cname(domain):

    try:

        domain = domain.lower().replace('http://', '').replace('https://', '').split('/')[0].strip()

        result = subprocess.run(
            ['dig', domain, 'CNAME', '+short'],
            capture_output=True,
            text=True,
            timeout=10
        )

        cname = result.stdout.strip()

        if cname:
            return f"{GREEN}[+] {domain} → {cname}{RESET}"
        else:
            return f"{PURPLE}[-] {domain} → No CNAME record{RESET}"

    except Exception as e:
        return f"{RED}[!] Error checking {domain}: {str(e)}{RESET}"


def process_single_target(target):

    print(f"\n{CYAN}[*] Checking:{RESET} {target}")
    print(CYAN + "-" * 50 + RESET)

    print(check_cname(target))


def process_list_file(file_path):

    try:

        with open(file_path, 'r') as f:
            domains = [line.strip() for line in f if line.strip()]

        print(f"{CYAN}[*] Loaded {len(domains)} targets{RESET}")
        print(f"{CYAN}[*] Checking for CNAME records...{RESET}")
        print(CYAN + "-" * 60 + RESET)

        for domain in domains:
            print(check_cname(domain))

    except FileNotFoundError:
        print(f"{RED}[!] File not found:{RESET} {file_path}")
        sys.exit(1)


def main():

    banner()

    parser = argparse.ArgumentParser(
        description="DNS CNAME Finder Tool - Discover CNAME records for domains and subdomains",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:

  Single target:
    cnfinder -u https://subdomain.example.com
    cnfinder -u subdomain.example.com

  List of targets:
    cnfinder -l subdomains.txt

  Save output to file:
    cnfinder -u example.com > output.txt
    cnfinder -l subdomains.txt > output.txt
"""
    )

    group = parser.add_mutually_exclusive_group(required=True)

    group.add_argument("-u", "--url", help="Single URL/domain to check")

    group.add_argument("-l", "--list", help="File containing list of domains")

    args = parser.parse_args()

    if args.url:
        process_single_target(args.url)

    elif args.list:
        process_list_file(args.list)


if __name__ == "__main__":
    main()
