""")


def check_cname(domain):
    try:
        domain = domain.lower().replace('http://', '').replace('https://', '').split('/')[0].strip()

        result = subprocess.run(
            ['dig', domain, 'CNAME', '+short'],
            capture_output=True,
            text=True,
            timeout=10
        )

        cname = result.stdout.strip()

        if cname:
            return f"[+] {domain} -> {cname}"
        else:
            return f"[-] {domain} - No CNAME record"

    except Exception as e:
        return f"[!] Error checking {domain}: {str(e)}"


def process_single_target(target):
    print(f"\n[*] Checking: {target}")
    print("-" * 50)
    print(check_cname(target))


def process_list_file(file_path):
    try:
        with open(file_path, 'r') as f:
            domains = [line.strip() for line in f if line.strip()]

        print(f"[*] Loaded {len(domains)} targets")
        print("[*] Checking for CNAME records...")
        print("-" * 60)

        for domain in domains:
            print(check_cname(domain))

    except FileNotFoundError:
        print(f"[!] File not found: {file_path}")
        sys.exit(1)


def main():
    banner()

    parser = argparse.ArgumentParser(
        description="DNS CNAME Finder Tool - Discover CNAME records for domains and subdomains",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:

  Single target:
    cnfinder -u https://subdomain.example.com
    cnfinder -u subdomain.example.com

  List of targets:
    cnfinder -l subdomains.txt

  Save output to file:
    cnfinder -u example.com > output.txt
    cnfinder -l subdomains.txt > output.txt
"""
    )

    group = parser.add_mutually_exclusive_group(required=True)
    group.add_argument("-u", "--url", help="Single URL/domain to check")
    group.add_argument("-l", "--list", help="File containing list of domains")

    args = parser.parse_args()

    if args.url:
        process_single_target(args.url)

    elif args.list:
        process_list_file(args.list)


if __name__ == "__main__":
    main()
